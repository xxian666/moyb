        gs.network = {colleagues:[], leader:null, boss:null};
        // 根据职位生成同事数量
        let num = jobId==='rider'?2:jobId==='clerk'?3:jobId==='office'?4:jobId==='coder'?5:6;
        for(let i=0;i<num;i++) gs.network.colleagues.push({name:names[randInt(0,names.length-1)]+i, affection:60});
