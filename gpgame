    ];
    const ACHIEVEMENTS = [
        {id:'watch10b',name:'寰宇名表典藏家',desc:'手表总价值超5亿',check:(gs)=>gs.ownedItems.filter(i=>i.type==='watch').reduce((s,i)=>s+i.price,0)>5e8},
        {id:'car5b',name:'豪车满贯',desc:'汽车总价值超5亿',check:(gs)=>gs.ownedItems.filter(i=>i.type==='car').reduce((s,i)=>s+i.price,0)>5e8},
        {id:'mood666',name:'风华正茂',desc:'心情≥666',check:(gs)=>gs.mood>=666},
        {id:'credit365',name:'盛名皆凭信誉来',desc:'诚信100持续365天',check:(gs)=>gs.credit100Days>=365},
        {id:'rich100b',name:'富可敌国',desc:'总资产>1000亿',check:(gs)=>totalAsset()>1e11},
    ];
    const MILESTONES = [100000,500000,1000000,5000000,20000000,50000000];

    // ---------- 随机事件库 ----------
    const RANDOM_EVENTS = [
        { title:'👛 捡到钱包', desc:'你捡到一个钱包，里面有不少现金和证件。', options:[
            {text:'归还失主', action:(gs)=>{ gs.credit+=3; gs.mood+=2; showToast('诚信+3 心情+2'); }},
            {text:'私吞', action:(gs)=>{
                if(Math.random()<0.3){ let cash=randInt(2000,10000); gs.cash+=cash; gs.mood+=5; showToast(`未被发现！获得¥${cash} 心情+5`); }
                else { gs.credit-=5; gs.mood-=5; showToast('被追回！诚信-5 心情-5'); }
            }}
        ]},
        { title:'💼 投资邀请', desc:'同事邀你一起炒币，需要投入5000元。', options:[
