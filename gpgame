    function networkPlay(who, idx=null){
        let cost = who==='leader'?1000:500;
        if(gs.stamina<10){showToast('体力不足','err');return;}
        if(gs.cash<cost){showToast('现金不足','err');return;}
        gs.stamina-=10; gs.cash-=cost;
        let target = who==='leader'?gs.network.leader:gs.network.colleagues[idx];
        if(Math.random()<0.3){ target.affection = Math.max(0, target.affection-1); showToast('互动太频繁，好感-1'); return; }
        let r=Math.random();
        if(who==='leader'){
            if(r<0.3) { target.affection = Math.min(100, target.affection+2); showToast('好感+2'); }
            else if(r<0.9) { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); }
            else showToast('没什么变化');
        }else{
            if(r<0.6) { target.affection = Math.min(100, target.affection+2); showToast('好感+2'); }
            else if(r<0.9) { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); }
            else showToast('没什么变化');
        }
    }
    function networkGift(who, idx=null){
        let cost = who==='leader'?10000:(who==='boss'?20000:3000);
        if(gs.cash<cost){showToast('现金不足','err');return;}
        gs.cash-=cost;
        let target = who==='leader'?gs.network.leader:(who==='boss'?gs.network.boss:gs.network.colleagues[idx]);
        if(Math.random()<0.3){ target.affection = Math.max(0, target.affection-1); showToast('互动太频繁，好感-1'); return; }
        let r=Math.random();
        if(who==='leader'){
            if(r<0.5) { target.affection = Math.min(100, target.affection+2); showToast('好感+2'); }
            else if(r<0.95) { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); }
            else { target.affection = Math.min(100, target.affection+3); showToast('好感+3！'); }
        }else if(who==='boss'){
            if(r<0.8) { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); }
            else { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); } // 实际80%+1,20%也+1？要求80%+1,20%+1 其实一样，我们改成80%+1,20%+2更合理
            if(r>=0.8) { target.affection = Math.min(100, target.affection+1); showToast('老板大悦，好感+2'); }
        }else{
            if(r<0.7) { target.affection = Math.min(100, target.affection+2); showToast('好感+2'); }
            else if(r<0.9) { target.affection = Math.min(100, target.affection+1); showToast('好感+1'); }
            else { target.affection = Math.min(100, target.affection+3); showToast('好感+3！'); }
        }
        // 检查老板好感>95获得永久buff
        if(who==='boss' && target.affection > 95 && !gs.bossBuff){
            gs.bossBuff = true;
            showToast('👑 获得老板赏识永久buff！工资+20%，购物8折');
        }
    }

    function doOvertime(){
        if(!gs.currentJob||gs.overtimeUsed||gs.stamina<30)return;
        gs.stamina-=30;gs.mood-=10;gs.cash+=100;gs.overtimeUsed=true;
        if(gs.network.boss && Math.random()<0.05){
            gs.network.boss.affection = Math.min(100, gs.network.boss.affection+1);
            showToast('加班被老板看见，好感+1');
            if(gs.network.boss.affection>95 && !gs.bossBuff){ gs.bossBuff=true; showToast('👑 老板赏识永久buff！'); }
        }
        refreshUI();
    }

    function doLeaveEarly(){
        if(!gs.currentJob||gs.leaveEarlyUsed)return;
        gs.leaveEarlyUsed=true;
        let baseSuccess = 0.645;
        // 根据人脉调整
        let leaderAff = gs.network.leader?gs.network.leader.affection:60;
        let colleagueAvg = gs.network.colleagues.length>0 ? gs.network.colleagues.reduce((s,c)=>s+c.affection,0)/gs.network.colleagues.length : 60;
        let successRate = baseSuccess;
        if(leaderAff < 60 || colleagueAvg < 60){
            successRate = 0.5; // 降低成功率
        }
        if(leaderAff > 85 && colleagueAvg > 85){
            successRate = 1 - (0.005+0.05+0.1); // 老板0.5%,领导5%,举报10% 剩余84.5%成功
        }
        let r=Math.random();
        if(gs.network.boss && r<0.005){ // 老板抓到
            gs.cash-=1000; gs.credit-=10; gs.currentJob=null; gs.daysWorkedInCycle=0; gs.lastPayDay=gs.day;
            gs.eventLog.unshift({day:gs.day,text:'🏃 被老板发现！辞退+诚信-10'});
        }else if(r<0.105){ // 同事举报
            gs.cash-=1000; gs.credit-=5;
            gs.eventLog.unshift({day:gs.day,text:'🏃 被同事举报，-1000诚信-5'});
        }else if(r<0.355){ // 领导发现
            if(leaderAff < 60 && Math.random()<0.3){ // 额外惩罚
                gs.mood-=5; gs.stamina = Math.max(0, gs.stamina-20);
                gs.eventLog.unshift({day:gs.day,text:'🏃 被领导骂并留下加班，心情-5体力-20'});
            }else{
                gs.cash-=1000; gs.credit-=5;
                gs.eventLog.unshift({day:gs.day,text:'🏃 被领导发现，-1000诚信-5'});
            }
        }else{
            gs.mood+=5;
            gs.eventLog.unshift({day:gs.day,text:'🏃 提前下班成功，心情+5'});
        }
        refreshUI();
        if(gs.credit<0)endGame('诚信归零');
    }

    function openJobModal(){let html='';JOB_DEFS.forEach((j,i)=>{let can=gs.cash>=j.reqCash&&totalAsset()>=j.reqAsset&&gs.credit>=j.reqCredit&&gs.skill>=j.reqSkill;html+=`<div style="margin:5px 0;"><strong>${j.icon} ${j.name}</strong> 月薪¥${j.salary}<br><small>💰≥${j.reqCash} 资产≥${j.reqAsset} 🤝≥${j.reqCredit} 🧠≥${j.reqSkill}</small><button class="btn btn-sm btn-outline" data-job-index="${i}" ${can?'':'disabled'}>${can?'应聘':'不满足'}</button></div>`;});document.getElementById('jobListContainer').innerHTML=html;document.getElementById('jobModal').style.display='flex';}
    document.addEventListener('click',e=>{if(e.target.closest('#jobListContainer button[data-job-index]')){let i=parseInt(e.target.dataset.jobIndex);takeJob(JOB_DEFS[i]);}if(e.target.closest('#loanListContainer button[data-loan-id]')){takeLoan(e.target.dataset.loanId);}});
    function takeJob(job){
        if(gs.cash<job.reqCash||totalAsset()<job.reqAsset||gs.credit<job.reqCredit||gs.skill<job.reqSkill)return;
        if(gs.currentJob) quitJob(true);
        gs.currentJob={...job};
        gs.daysWorkedInCycle=0; gs.lastPayDay=gs.day;
        generateNetwork(job.id);
        document.getElementById('jobModal').style.display='none';
        refreshUI();
    }
    function quitJob(silent=false){
        if(!gs.currentJob)return;
        if(!silent){
            let payout=Math.round(gs.currentJob.salary*(gs.daysWorkedInCycle/30)*0.9);
            gs.cash+=payout;
        }
        gs.currentJob=null; gs.daysWorkedInCycle=0;
        gs.network = {colleagues:[], leader:null, boss:null};
        refreshUI();
    }
    function openLoanModal(){let html='';LOAN_PRODUCTS.forEach(l=>{let can=gs.credit>=l.minCredit&&!gs.loan;html+=`<div>${l.name} ¥${l.amount} <button data-loan-id="${l.id}" ${can?'':'disabled'}>申请</button></div>`;});document.getElementById('loanListContainer').innerHTML=html;document.getElementById('loanModal').style.display='flex';}
    function takeLoan(pid){let p=LOAN_PRODUCTS.find(l=>l.id===pid);if(!p||gs.loan)return;gs.loan={amount:p.amount,rate:p.rate,days:0};gs.cash+=p.amount;document.getElementById('loanModal').style.display='none';refreshUI();}
    function repayLoan(){if(!gs.loan||gs.cash<gs.loan.amount)return;gs.cash-=gs.loan.amount;gs.loan=null;refreshUI();}

    function updateJobLoanUI(){
        let jobCard=document.getElementById('jobInfoCard');let findBtn=document.getElementById('btnFindJob');let quitBtn=document.getElementById('btnQuitJob');let overtimeBtn=document.getElementById('btnOvertime');let leaveBtn=document.getElementById('btnLeaveEarly');
        if(gs.currentJob){jobCard.innerHTML=`💼 ${gs.currentJob.icon} ${gs.currentJob.name} 月薪¥${gs.currentJob.salary} | 已工作${gs.daysWorkedInCycle}天`;findBtn.style.display='none';quitBtn.style.display='inline-block';overtimeBtn.style.display='inline-block';leaveBtn.style.display='inline-block';}else{jobCard.innerHTML='暂无工作';findBtn.style.display='inline-block';quitBtn.style.display='none';overtimeBtn.style.display='none';leaveBtn.style.display='none';}
        document.getElementById('btnRepayLoan').style.display=gs.loan?'inline-block':'none';
        document.getElementById('btnLeverage').style.display=(gs.credit100Days>=30)?'inline-block':'none';
    }

    // 原有渲染函数保持不变
    function renderMarket(){
        let html='';['stock','fund','metal'].forEach(cat=>{
            html+=`<span class="cat-tag cat-${cat}">${cat==='stock'?'📈':cat==='fund'?'📊':'🪙'}</span>`;
            assetDefs.filter(d=>d.cat===cat).forEach(d=>{
                let a=gs.assets[d.id];if(!a)return;
                let prev=a.ohlc.length>1?a.ohlc[a.ohlc.length-2].close:a.currentPrice;
                let chg=((a.currentPrice-prev)/prev*100);
                if(isNaN(chg))chg=0;
                let cls=chg>0.03?'chg-up':(chg<-0.03?'chg-down':'chg-flat');
                html+=`<div class="asset-row${gs.selectedAssetId===d.id?' selected':''}" onclick="selectAsset('${d.id}')">
                    <div class="asset-left"><span class="a-icon icon-${cat}">${d.icon}</span><span>${d.name}</span></div>
                    <div class="asset-right">
                        <span class="risk-tag risk-${d.risk}">${d.risk==='low'?'低':d.risk==='mid'?'中':'高'}</span>
                        <span>¥${a.currentPrice.toFixed(2)}</span>
                        <span class="a-change ${cls}">${chg>=0?'+':''}${chg.toFixed(2)}%</span>
                    </div>
                </div>`;
            });
        });
        document.getElementById('marketList').innerHTML=html;
    }
    function safePct(v,b){if(!b||b===0||isNaN(v)||isNaN(b))return'--';let p=((v-b)/b)*100;return isFinite(p)?(p>=0?'+':'')+p.toFixed(2)+'%':'--';}
    function renderHoldings(){
        let html='';
        for(let[id,h]of Object.entries(gs.holdings)){
            let a=gs.assets[id];if(!a)continue;
            let cp=a.currentPrice;if(isNaN(cp))continue;
            let avg=h.totalCost/h.qty;if(isNaN(avg))avg=cp;
            let yc=a.ohlc.length>1?a.ohlc[a.ohlc.length-2].close:cp;
            html+=`<div class="holding-card"><span>${a.icon} ${a.name} ×${h.qty}</span><span style="color:${cp>=avg?'var(--green)':'var(--red)'}">成本${safePct(cp,avg)}</span><span style="color:${cp>=yc?'var(--green)':'var(--red)'}">日${safePct(cp,yc)}</span><button class="btn btn-sm btn-outline" onclick="quickSell('${id}')">卖</button></div>`;
        }
        document.getElementById('holdingsList').innerHTML=html||'暂无持仓';
    }
    function renderProperties(){
        let html='';PROPERTY_DEFS.forEach(p=>{if(gs.properties[p.id])html+=`<div>${p.icon} ${p.name} (已拥有)</div>`;else{let price = gs.bossBuff?Math.round(p.price*0.8):p.price;html+=`<button class="btn btn-sm btn-outline" onclick="buyProperty('${p.id}')">${p.icon} ${p.name} ¥${price.toLocaleString()}</button>`;}});
        document.getElementById('propertyList').innerHTML=html||'暂无房产';
    }
    function renderActivities(){
        let html='';
        html+=`<button class="act-btn" onclick="doActivity('cheapfood')">🍜便宜美食 <small>💰1~100 ❤+2~5 ⚡20~40</small></button>`;
        html+=`<button class="act-btn" onclick="doActivity('fancyfood')">🍽️精致大餐 <small>💰200~500 ❤+10 ⚡20~40</small></button>`;
        html+=`<button class="act-btn" onclick="doActivity('gaming')">🎮打游戏 <small>💰0 ❤+5 ⚡10~20</small></button>`;
        html+=`<button class="act-btn" onclick="doActivity('social')">🎉社交 <small>💰100~200 ❤?-4~+15 ⚡10~20</small></button>`;
        html+=`<button class="act-btn" onclick="donate()">🎗️捐款1000 <small>诚信+1 (日限1次)</small></button>`;
        html+=`<button class="act-btn" onclick="volunteer()">🧹劳动 <small>⚡40 诚信+3</small></button>`;
        html+=`<button class="act-btn" onclick="learn()">📚学习 <small>⚡30 技能+2</small></button>`;
        let lotteryCd = gs.lotteryNoCooldown?0:7-(gs.day-gs.lastLotteryDay);
        html+=`<button class="act-btn" onclick="buyLottery()">🎰彩票 ¥${gs.bossBuff?1600:2000} <small>${lotteryCd>0?lotteryCd+'天后可买':'可购买'}</small></button>`;
        html+=`<div class="section-title">🛍️购物</div>`;
        SHOP_ITEMS.forEach(item=>{let price=gs.bossBuff?Math.round(item.price*0.8):item.price;html+=`<button class="act-btn" onclick="buyShopItem({type:'${item.type}',name:'${item.name}',price:${item.price},icon:'${item.icon}'})">${item.icon}${item.name} ¥${price.toLocaleString()}</button>`;});
        html+=`<div class="section-title">📊定投</div><button class="act-btn" onclick="toggleAutoInvest()">${gs.autoInvest.enabled?'关闭定投 (每日1000)':'开启定投 (每日1000买入稳健基金)'}</button>`;
        document.getElementById('activityList').innerHTML=html;
    }
    function toggleAutoInvest(){gs.autoInvest.enabled=!gs.autoInvest.enabled;refreshUI();}
    function doActivity(type){
        if(gs.gameOver)return;
        let cash=0,mood=0,sta=0,reason='';
        const foods=['在小吃摊吃了碗面','点了一份外卖','买了个饭团'];
        const fancy=['去米其林享受了一顿','聚餐奢侈了一把'];
        const games=['通宵打游戏','玩了几局放松'];
        const goodS=['与朋友聚会很开心','认识了新朋友'];
        const badS=['和朋友闹掰了','聚会中被冷落'];
        switch(type){
            case'cheapfood':sta=randInt(20,40);if(gs.stamina<sta)return showToast('体力不足','err');cash=randInt(1,100);mood=randInt(2,5);reason=foods[randInt(0,foods.length-1)];break;
            case'fancyfood':sta=randInt(20,40);if(gs.stamina<sta)return;cash=randInt(200,500);mood=10;reason=fancy[randInt(0,fancy.length-1)];break;
            case'gaming':sta=randInt(10,20);if(gs.stamina<sta)return;mood=5;reason=games[randInt(0,games.length-1)];break;
            case'social':
                sta=randInt(10,20);if(gs.stamina<sta)return;cash=randInt(100,200);
                let r=Math.random();
                if(r<0.05){
                    let stocks=assetDefs.filter(d=>d.cat==='stock').map(d=>d.id);
                    gs.recommendedStock=stocks[randInt(0,stocks.length-1)];
                    reason=`遇到金融人士！推荐关注${gs.assets[gs.recommendedStock]?.name}`;
                    mood=15;
                }else{
                    mood=Math.random()<0.3?-randInt(2,4):15;
                    reason=mood>=0?goodS[randInt(0,goodS.length-1)]:badS[randInt(0,badS.length-1)];
                }
                break;
        }
        if(cash>gs.cash)return showToast('当前现金不足无法购买','err');
        gs.cash-=cash;gs.stamina-=sta;gs.mood+=mood;                  
        gs.eventLog.unshift({day:gs.day,text:`🎭 ${reason} 心情${mood>=0?'+'+mood:mood}`});
        if(gs.mood<0)endGame('心情崩溃');refreshUI();
    }
    function renderEvents(){let html='';gs.eventLog.slice(0,20).forEach(e=>{html+=`<div class="event-item"><span class="day-tag">D${e.day}</span>${e.text}</div>`;});document.getElementById('eventLogContent').innerHTML=html||'暂无';}
    function renderAchievements(){
        let html='';ACHIEVEMENTS.forEach(a=>{let unlocked=gs.unlockedAchievements.has(a.id);html+=`<div class="achievement-item${unlocked?'':' locked'}"><span>${unlocked?'🏆':'🔒'}</span><div><strong>${a.name}</strong><br><small>${a.desc}</small></div></div>`;});
        document.getElementById('achievementList').innerHTML=html||'暂无成就';
    }
    function renderMilestones(){
        let html='';let ta=totalAsset();
        MILESTONES.forEach(m=>{let achieved=ta>=m;html+=`<div class="achievement-item${achieved?'':' locked'}"><span>${achieved?'✅':'⬜'}</span><div><strong>资产达到 ¥${m.toLocaleString()}</strong><br><small>${achieved?'已达成 (奖金已发放)':'未达成'}</small></div></div>`;});
        document.getElementById('milestoneList').innerHTML=html;
    }
    function checkAchievements(){ACHIEVEMENTS.forEach(a=>{if(!gs.unlockedAchievements.has(a.id)&&a.check(gs)){gs.unlockedAchievements.add(a.id);showToast(`🏅 成就解锁：${a.name}`);}});}

    function selectAsset(id){
        gs.selectedAssetId=id;
        document.getElementById('tradeQty').value=100;
        refreshUI();
        switchView('trade');
        drawChart(id);
    }
    function quickSell(id){gs.selectedAssetId=id;document.getElementById('tradeQty').value=gs.holdings[id]?.qty||0;refreshUI();switchView('trade');}
    function switchView(name){document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));document.getElementById('view-'+name).classList.add('active');document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));document.querySelector(`.nav-item[data-view="${name}"]`).classList.add('active');}
    function showToast(msg,type=''){let c=document.getElementById('toastContainer'),t=document.createElement('div');t.className='toast'+(type==='err'?' err':'');t.textContent=msg;c.appendChild(t);setTimeout(()=>t.remove(),2000);}

    function updateTradeInfo(){
        let info=document.getElementById('tradeSelectedInfo'),est=document.getElementById('tradeEstimate'),qty=parseInt(document.getElementById('tradeQty').value)||0;
        if(!gs.selectedAssetId || !gs.assets[gs.selectedAssetId]){
            info.textContent='👆 请选择资产';
            est.textContent='--';
            return;
        }
        let a=gs.assets[gs.selectedAssetId];
        info.innerHTML=`已选 <strong>${a.name}</strong> ¥${a.currentPrice.toFixed(2)}`;
        est.textContent=qty>0?`预计 ¥${(a.currentPrice*qty).toFixed(2)}`:'--';
    }

    // K线绘图
    function drawChart(id){
        let asset=gs.assets[id];if(!asset)return;
        let canvas=document.getElementById('klineCanvas');
        let container=document.getElementById('chartPanel');
        let ctx=canvas.getContext('2d');
        let ohlc=asset.ohlc.slice(-50);
        if(!ohlc.length)return;
        container.style.display='block';
        canvas.width=container.clientWidth-8;
        canvas.height=100;
        let w=canvas.width,h=canvas.height;
        ctx.clearRect(0,0,w,h);
        let min=Math.min(...ohlc.map(d=>d.low)),max=Math.max(...ohlc.map(d=>d.high)),range=max-min||1;
        let candleWidth=Math.max(1,(w-10)/ohlc.length-2);
        ohlc.forEach((d,i)=>{
            let x=5+i*(candleWidth+2);
            let openY=h-15-((d.open-min)/range)*(h-30);
            let closeY=h-15-((d.close-min)/range)*(h-30);
            let highY=h-15-((d.high-min)/range)*(h-30);
            let lowY=h-15-((d.low-min)/range)*(h-30);
            ctx.strokeStyle='#8b929a';
            ctx.beginPath();ctx.moveTo(x+candleWidth/2,highY);ctx.lineTo(x+candleWidth/2,lowY);ctx.stroke();
            ctx.fillStyle=d.close>=d.open?'#4ade80':'#f87171';
            ctx.fillRect(x,Math.min(openY,closeY),candleWidth,Math.abs(closeY-openY)||1);
        });
        let maxVol=Math.max(...ohlc.map(d=>d.volume));
        let volBottom=h-5;
        ohlc.forEach((d,i)=>{
            let x=5+i*(candleWidth+2);
            let barH=(d.volume/maxVol)*15;
            ctx.fillStyle=d.close>=d.open?'rgba(74,222,128,0.5)':'rgba(248,113,113,0.5)';
            ctx.fillRect(x,volBottom-barH,candleWidth,barH);
        });
        document.getElementById('volInfo').textContent=`成交量: ${ohlc[ohlc.length-1].volume}`;
        let closes=ohlc.map(d=>d.close);
        function ema(data,n){let k=2/(n+1);let arr=[data[0]];for(let i=1;i<data.length;i++) arr.push(data[i]*k + arr[i-1]*(1-k));return arr;}
        if(closes.length>=26){
            let ema12=ema(closes,12),ema26=ema(closes,26);
            ctx.strokeStyle='#f0b90b';ctx.lineWidth=1;ctx.beginPath();
            for(let i=0;i<ohlc.length;i++){let x=5+i*(candleWidth+2)+candleWidth/2;let y=h-15-((ema12[i]-min)/range)*(h-30);if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);}
            ctx.stroke();
            ctx.strokeStyle='#60a5fa';ctx.beginPath();
            for(let i=0;i<ohlc.length;i++){let x=5+i*(candleWidth+2)+candleWidth/2;let y=h-15-((ema26[i]-min)/range)*(h-30);if(i===0)ctx.moveTo(x,y);else ctx.lineTo(x,y);}
            ctx.stroke();
            let dif=ema12.map((v,i)=>v-ema26[i]),dea=ema(dif,9),macdVal=2*(dif[dif.length-1]-dea[dea.length-1]);
            document.getElementById('macdInfo').textContent=`MACD: ${macdVal.toFixed(3)}`;
        }else document.getElementById('macdInfo').textContent='MACD: 数据不足';
    }

    document.querySelectorAll('.nav-item').forEach(i=>i.addEventListener('click',()=>switchView(i.dataset.view)));
    document.getElementById('btnNextDay').addEventListener('click',()=>{if(gs.gameOver && gs.winAchieved) gs.gameOver=false; if(!gs.gameOver || gs.winAchieved) advanceDay();});
    document.getElementById('btnBuy').addEventListener('click',()=>{if(!gs.selectedAssetId)return;let r=buyAsset(gs.selectedAssetId,parseInt(document.getElementById('tradeQty').value)||0);if(r)refreshUI();});
    document.getElementById('btnSell').addEventListener('click',()=>{if(!gs.selectedAssetId)return;let r=sellAsset(gs.selectedAssetId,parseInt(document.getElementById('tradeQty').value)||0);if(r)refreshUI();});
    document.getElementById('tradeQty').addEventListener('input',updateTradeInfo);
    initAssets();refreshUI();switchView('trade');
</script>
