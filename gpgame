    function randGauss(m=0,s=1){let u=1-Math.random(),v=1-Math.random();return m+Math.sqrt(-2*Math.log(u+0.0001))*Math.cos(2*Math.PI*v)*s;}
    function randInt(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
    function randFloat(a,b){return Math.random()*(b-a)+a;}
    function price(id){return gs.assets[id]?.currentPrice??0;}
    function totalAsset(){
        let t = gs.cash;
        for(let[k,v] of Object.entries(gs.holdings)){
            let p = price(k);
            if(isNaN(p) || !isFinite(p)) continue;
            t += v.qty * p;
        }
        for(let k in gs.properties) t += gs.properties[k].price;
        return isFinite(t) ? t : gs.lastTotalAsset || INITIAL_CASH;
    }
    function holdingVal(){
        let t=0;
        for(let[k,v] of Object.entries(gs.holdings)){
            let p = price(k);
            if(isNaN(p) || !isFinite(p)) continue;
            t += v.qty * p;
        }
        return isFinite(t) ? t : 0;
    }

    function initAssets(){assetDefs.forEach(d=>{let ohlc=[],close=d.initPrice;for(let i=0;i<100;i++){let open=close;let change=Math.exp(randGauss(0,d.vol*0.8));close=Math.max(0.01,close*change);if(isNaN(close)||!isFinite(close))close=open;let high=close*(1+Math.abs(randGauss(0,d.vol*0.3))),low=close*(1-Math.abs(randGauss(0,d.vol*0.3)));ohlc.push({open,high,low,close,volume:randInt(5000,50000)});}gs.assets[d.id]={...d,ohlc,currentPrice:close};});}

