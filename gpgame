    function advanceDay(){
        if(gs.gameOver && !gs.winAchieved) return;
        if(gs.winAchieved) gs.gameOver = false;
        gs.day++;gs.stamina=MAX_STAMINA;gs.overtimeUsed=gs.leaveEarlyUsed=false;
        if(gs.credit===100)gs.credit100Days++;else gs.credit100Days=0;
        let events=[];

        // 工作消耗
        if(gs.currentJob&&gs.stamina>=20){gs.stamina-=20;gs.daysWorkedInCycle++;gs.mood-=3;events.push({text:`💼 打工：${gs.currentJob.name}`});}

        // 资产价格更新
        for(let[id,asset]of Object.entries(gs.assets)){
            let last=asset.ohlc[asset.ohlc.length-1],open=last.close;
            let volMod=asset.vol*(1-Math.min(5,(gs.skill-60)*0.1)/100);
            let change=Math.exp(randGauss(0,volMod*0.8));
            let close=Math.max(0.01,open*change);
            if(isNaN(close)||!isFinite(close))close=open;
            if(gs.recommendedStock===id){
                close=close*(1+randFloat(0.05,0.15));
                if(isNaN(close))close=open;
            }
            if(close>open*1.1)close=open*1.1;if(close<open*0.9)close=open*0.9;
            let high=close*(1+Math.abs(randGauss(0,volMod*0.3))),low=close*(1-Math.abs(randGauss(0,volMod*0.3)));
            asset.ohlc.push({open,high,low,close,volume:randInt(5000,50000)});
            if(asset.ohlc.length>300)asset.ohlc.shift();
            asset.currentPrice=close;
        }
        gs.recommendedStock=null;

        // 房产租金
        for(let[id,p]of Object.entries(gs.properties)){let def=PROPERTY_DEFS.find(d=>d.id===id);if(def){gs.cash+=def.rent;events.push({text:`🏠 ${def.name} 租金 +¥${def.rent}`});}}
        // 定投
        if(gs.autoInvest.enabled){let fund=gs.assets[gs.autoInvest.fundId];if(fund&&gs.cash>=gs.autoInvest.amount){let qty=Math.floor(gs.autoInvest.amount/fund.currentPrice);if(qty>0){buyAsset(gs.autoInvest.fundId,qty);events.push({text:`📊 定投 ${fund.name} ×${qty}`});}}}
        let cost=randInt(50,200);gs.cash-=cost;events.push({text:`🧾 生活开支 ¥${cost}`});
        if(gs.loan){let int=Math.round(gs.loan.amount*gs.loan.rate);gs.cash-=int;gs.loan.days++;}
        if(gs.leverage){let int=Math.round(gs.leverage.amount*0.002);gs.cash-=int;}
        if(Math.random()<0.22){let chg=randInt(200,3000);gs.cash+=chg;events.push({text:`🍀 +¥${chg}`});}
        if(gs.day-gs.lastPayDay>=30&&gs.currentJob){
            let pay = Math.round(gs.currentJob.salary*(gs.daysWorkedInCycle/30));
            if(gs.bossBuff) pay = Math.round(pay * 1.2); // 老板buff加薪
            gs.cash+=pay;gs.mood+=5;gs.lastPayDay=gs.day;gs.daysWorkedInCycle=0;
            events.push({text:`💵 发薪 ¥${pay}`});
        }

        // 老板辞退检查
        if(gs.currentJob && gs.network.boss && gs.network.boss.affection < 40 && Math.random() < 0.8){
            events.push({text:'💼 老板对你不满，你被辞退了！'});
            quitJob(true);
        }

        let ta=totalAsset();
        if(isNaN(ta)){gs.cash=INITIAL_CASH;gs.holdings={};gs.properties={};ta=gs.cash;}
        if(ta>gs.lastTotalAsset)gs.consecutiveProfitDays++;else gs.consecutiveProfitDays=0;
        if(gs.consecutiveProfitDays>=5){gs.mood+=10;gs.cash+=1000;events.push({text:'📈 连续5日盈利！+1000 心情+10'});gs.consecutiveProfitDays=0;}
        gs.lastTotalAsset=ta;
        for(let m of MILESTONES){if(ta>=m&&gs.lastMilestone<m){gs.cash+=Math.round(ta*0.05);gs.lastMilestone=m;events.push({text:`🎯 里程碑！资产达${m.toLocaleString()} 奖金5%`});break;}}
        events.forEach(e=>gs.eventLog.unshift({day:gs.day,text:e.text}));

        // 随机事件触发 (4~20天间隔)
        if(gs.day - gs.lastEventDay >= randInt(4,20)){
            triggerRandomEvent();
            gs.lastEventDay = gs.day;
        }

        if(gs.mood<0){endGame('心情崩溃');return;}if(gs.cash<-1000){endGame('破产');return;}if(gs.credit<0){endGame('诚信归零');return;}
        if(ta>=TARGET&&!gs.winAchieved){gs.winAchieved=true;gs.gameOver=true;showWinModal();}
        checkAchievements();refreshUI();
    }

