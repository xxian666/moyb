    function buyAsset(id,qty){
        if(gs.gameOver||qty<=0)return false;
        let p=price(id);
        if(isNaN(p)||!isFinite(p))return false;
        let cost=p*qty;
        if(cost>gs.cash){showToast('当前现金不足无法购买','err');return false;}
        gs.cash-=cost;
        if(!gs.holdings[id])gs.holdings[id]={qty:0,totalCost:0};
        gs.holdings[id].qty+=qty;
        gs.holdings[id].totalCost+=cost;
        if(isNaN(gs.holdings[id].totalCost))gs.holdings[id].totalCost=cost;
        showToast(`购买成功，已买入 ${gs.assets[id].name} ×${qty}`);
        return true;
    }
    function sellAsset(id,qty){
        let h=gs.holdings[id];
        if(!h||qty>h.qty){showToast('持仓不足','err');return false;}
        let p=price(id);
        if(isNaN(p))return false;
        let rev=p*qty;
        let avg=h.totalCost/h.qty;
        if(isNaN(avg)||!isFinite(avg))avg=p;
        h.totalCost-=avg*qty;
        h.qty-=qty;
        if(h.qty<=0)delete gs.holdings[id];
        gs.cash+=rev;
        showToast(`卖出成功，已卖出 ${gs.assets[id].name} ×${qty}`);
        return true;
    }

