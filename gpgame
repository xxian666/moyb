<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>🎯 赚够一个亿 </title>
    <style>
        :root {
            --bg: #0a0e14; --card: #131820; --card2: #1a2230; --border: #252d3a;
            --text: #d1d5db; --text2: #8b929a; --gold: #f0b90b; --green: #4ade80;
            --red: #f87171; --blue: #60a5fa; --pink: #f472b6; --teal: #2dd4bf;
            --purple: #c084fc; --input-bg: #0d1117;
            --font-mono: 'SF Mono','Cascadia Code','Consolas',monospace;
            --font-sans: -apple-system,BlinkMacSystemFont,'PingFang SC','Microsoft YaHei',sans-serif;
        }
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background: #05080d; color: var(--text); font-family: var(--font-sans); height: 100vh; overflow: hidden; display: flex; justify-content: center; align-items: center; user-select: none; }
        .game-container { width: 100%; max-width: 480px; height: 100vh; display: flex; flex-direction: column; background: var(--bg); position: relative; }
        .top-bar { background: var(--card); border-bottom: 1px solid var(--border); padding: 6px 8px; flex-shrink: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 3px; font-size: 0.65em; }
        .stat-item { display: flex; justify-content: space-between; align-items: center; padding: 3px 5px; background: var(--card2); border-radius: 3px; }
        .stat-value { font-weight: 700; font-family: var(--font-mono); }
        .gold { color: var(--gold); } .green { color: var(--green); } .pink { color: var(--pink); } .teal { color: var(--teal); } .blue { color: var(--blue); } .purple { color: var(--purple); }
        .progress-mini { grid-column: span 2; display: flex; align-items: center; gap: 4px; }
        .prog-bar { flex:1; height:5px; background:#1e293b; border-radius:3px; overflow:hidden; }
        .prog-fill { height:100%; background:linear-gradient(90deg,#f0b90b,#f7c948); border-radius:3px; transition: width 0.3s; }
        .content-area { flex:1; overflow-y: auto; padding: 4px; }
        .view { display: none; } .view.active { display: block; }
        .section-title { font-size:0.65em; color:var(--text2); margin:6px 0 3px; border-bottom:1px solid var(--border); padding-bottom:2px; }
        .cat-tag {display:inline-block; font-size:0.5em; padding:1px 4px; border-radius:2px; margin:2px 0; font-weight:600;}
        .cat-stock{background:rgba(248,113,113,0.2);color:#fca5a5;} .cat-fund{background:rgba(96,165,250,0.2);color:#93c5fd;} .cat-metal{background:rgba(240,185,11,0.2);color:#fcd34d;}
        .asset-row { display:flex; align-items:center; padding:5px 6px; cursor:pointer; gap:6px; border:1px solid transparent; font-size:0.62em; justify-content: space-between; }
        .asset-row:hover,.asset-row.selected{background:var(--card2);border-color:var(--border);}
        .asset-left { display:flex; align-items:center; gap:4px; flex:1; min-width:0; }
        .asset-right { display:flex; align-items:center; gap:6px; flex-shrink:0; }
        .a-icon{width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.7em;flex-shrink:0;}
        .icon-stock{background:rgba(248,113,113,0.2);color:#fca5a5;} .icon-fund{background:rgba(96,165,250,0.2);color:#93c5fd;} .icon-metal{background:rgba(240,185,11,0.2);color:#fcd34d;}
        .risk-tag{font-size:0.45em;padding:0px 2px;border-radius:2px;}
        .risk-low{background:rgba(74,222,128,0.2);color:#4ade80;} .risk-mid{background:rgba(251,146,60,0.2);color:#fb923c;} .risk-high{background:rgba(248,113,113,0.2);color:#f87171;}
        .chg-up{color:#fff;background:rgba(248,113,113,0.7);} .chg-down{color:#fff;background:rgba(74,222,128,0.7);} .chg-flat{color:var(--text2);background:rgba(139,146,154,0.3);}
        .btn { padding:5px 10px; border:none; border-radius:4px; cursor:pointer; font-weight:700; font-size:0.6em; }
        .btn-sm { padding:3px 7px; font-size:0.55em; }
        .btn-buy{background:#dc2626;color:#fff;} .btn-sell{background:#16a34a;color:#fff;}
        .btn-outline{background:transparent;border:1px solid var(--border);color:var(--text);}
        .holding-card { background:var(--card2); border-radius:4px; padding:6px; margin:2px 0; display:flex; align-items:center; gap:4px; font-size:0.62em; flex-wrap:wrap; }
        .act-btn { display:flex; align-items:center; gap:5px; background:var(--card2); border:1px solid var(--border); border-radius:4px; padding:8px; margin:3px 0; cursor:pointer; font-size:0.65em; color:var(--text); }
        .act-btn:active{opacity:0.8;} .act-btn:disabled{opacity:0.4; pointer-events:none;}
        .event-item { padding:3px 0; border-bottom:1px solid rgba(37,45,58,0.6); font-size:0.58em; line-height:1.3; }
        .nav-bar { display:flex; background:var(--card); border-top:1px solid var(--border); flex-shrink:0; height:50px; }
        .nav-item { flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; color:var(--text2); font-size:0.5em; cursor:pointer; }
        .nav-item.active { color:var(--gold); }
        .bottom-action { padding:4px 8px; background:var(--bg); }
        .btn-next-day { width:100%; padding:10px; border:none; border-radius:16px; background:linear-gradient(135deg,#f0b90b,#e8a800); color:#000; font-weight:800; font-size:0.75em; }
        .modal-overlay { position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.85); display:flex; align-items:center; justify-content:center; z-index:1000; }
        .modal { background:var(--card); border:2px solid var(--gold); border-radius:8px; padding:16px; text-align:center; max-width:90%; width:350px; box-shadow:0 0 40px rgba(240,185,11,0.3); position:relative; }
        .toast { position:fixed; top:16px; left:50%; transform:translateX(-50%); background:#16a34a; color:#fff; padding:6px 14px; border-radius:14px; font-weight:700; font-size:0.65em; z-index:999; animation:toastIn 0.3s; }
        .toast.err{background:#dc2626;}
        @keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(-20px);}to{opacity:1;transform:translateX(-50%) translateY(0);}}
        .chart-container { background:var(--card); border-radius:4px; padding:4px; margin-top:6px; }
        canvas { width:100%; height:100px; display:block; }
        .achievement-item { padding:6px; margin:3px 0; background:var(--card2); border-radius:3px; font-size:0.65em; display:flex; align-items:center; gap:6px; }
        .achievement-item.locked { opacity:0.6; }
        .network-card { background:var(--card2); border-radius:4px; padding:6px; margin:4px 0; display:flex; align-items:center; gap:6px; font-size:0.6em; }
        .network-card button { margin-left:auto; }
    </style>
</head>
<body>
<div class="game-container">
    <div class="top-bar">
        <div class="stat-item"><span>💰总资产</span><span class="stat-value gold" id="topTotalAsset" onclick="openAssetDetail()" style="cursor:pointer; text-decoration:underline;">100,000</span></div>
        <div class="stat-item"><span>💵现金</span><span class="stat-value green" id="topCash">100,000</span></div>
        <div class="stat-item"><span>😊心情</span><span class="stat-value pink" id="topMood">60</span></div>
        <div class="stat-item"><span>⚡体力</span><span class="stat-value teal" id="topStamina">100/100</span></div>
        <div class="stat-item"><span>🤝诚信</span><span class="stat-value blue" id="topCredit">100</span></div>
        <div class="stat-item"><span>🧠技能</span><span class="stat-value purple" id="topSkill">60</span></div>
        <div class="progress-mini"><span>🎯</span><div class="prog-bar"><div class="prog-fill" id="topProgress" style="width:0.1%;"></div></div><span id="topProgressPct">0.1%</span></div>
    </div>
    <div class="content-area" id="contentArea">
        <div class="view active" id="view-trade">
            <div class="section-title">📊 行情</div><div id="marketList"></div>
            <div style="margin:5px 0;font-size:0.55em;color:var(--text2);">💡 点击资产查看K线 | 低🟢/中🟠/高🔴风险</div>
            <div id="chartPanel" class="chart-container" style="display:none;"><canvas id="klineCanvas"></canvas><div style="display:flex;justify-content:space-between;font-size:0.5em;margin-top:2px;"><span id="macdInfo"></span><span id="volInfo"></span></div></div>
            <div style="margin-top:5px;border-top:1px solid var(--border);padding-top:5px;">
                <div id="tradeSelectedInfo" style="font-size:0.6em;color:var(--text2);">👆 请选择资产</div>
                <div style="display:flex;gap:3px;align-items:center;margin-top:2px;">
                    <input type="number" id="tradeQty" placeholder="数量" min="1" value="100" style="width:55px;background:var(--input-bg);border:1px solid var(--border);color:var(--text);padding:4px;border-radius:3px;font-family:var(--font-mono);">
                    <span id="tradeEstimate" style="font-size:0.55em;">--</span>
                    <button class="btn btn-buy btn-sm" id="btnBuy">买入</button><button class="btn btn-sell btn-sm" id="btnSell">卖出</button>
                </div>
            </div>
        </div>
        <div class="view" id="view-assets">
            <div class="section-title">📋 持仓</div><div id="holdingsList"></div>
            <div class="section-title">💼 工作与贷款</div>
            <div id="jobInfoCard" style="font-size:0.6em;"></div><div id="loanInfoCard" style="font-size:0.6em;"></div>
            <div style="display:flex;gap:3px;flex-wrap:wrap;margin-top:4px;">
                <button class="btn btn-outline btn-sm" id="btnFindJob" onclick="openJobModal()">🔍 找工作</button>
                <button class="btn btn-outline btn-sm" id="btnQuitJob" style="display:none;" onclick="quitJob()">辞职</button>
                <button class="btn btn-outline btn-sm" id="btnOvertime" style="display:none;" onclick="doOvertime()">🔥加班</button>
                <button class="btn btn-outline btn-sm" id="btnLeaveEarly" style="display:none;" onclick="doLeaveEarly()">🏃提前下班</button>
                <button class="btn btn-outline btn-sm" onclick="openLoanModal()">🏦 贷款</button>
                <button class="btn btn-outline btn-sm" id="btnRepayLoan" style="display:none;" onclick="repayLoan()">还贷</button>
                <button class="btn btn-outline btn-sm" id="btnLeverage" onclick="openLeverageModal()">📈 杠杆</button>
            </div>
            <div class="section-title" id="networkTitle" style="display:none;">👥 人脉</div>
            <div id="networkList"></div>
        </div>
        <div class="view" id="view-activities">
            <div class="section-title">🎭 活动</div><div id="activityList"></div>
            <div class="section-title">🏠 房产</div><div id="propertyList"></div>
        </div>
        <div class="view" id="view-events"><div class="section-title">📰 事件</div><div id="eventLogContent"></div></div>
        <div class="view" id="view-achievements">
            <div class="section-title">🏅 成就</div><div id="achievementList"></div>
            <div class="section-title">🎯 里程碑</div><div id="milestoneList"></div>
        </div>
    </div>
    <div class="nav-bar">
        <div class="nav-item active" data-view="trade"><span>📊</span>交易</div>
        <div class="nav-item" data-view="assets"><span>📋</span>资产</div>
        <div class="nav-item" data-view="activities"><span>🎭</span>活动</div>
        <div class="nav-item" data-view="events"><span>📰</span>事件</div>
        <div class="nav-item" data-view="achievements"><span>🏅</span>成就</div>
    </div>
    <div class="bottom-action"><button class="btn-next-day" id="btnNextDay">⏭️ 进入下一天</button></div>
</div>
<div id="toastContainer"></div>
<!-- 资产详情弹窗 -->
<div class="modal-overlay" id="assetDetailModal" style="display:none;"><div class="modal" style="width:90%;max-width:400px;font-size:0.9em;text-align:left;"><h2 style="text-align:center;">📊 资产明细</h2><div id="assetDetailContent"></div><button class="btn-outline" onclick="document.getElementById('assetDetailModal').style.display='none'" style="margin-top:10px;">关闭</button><button class="btn-sm btn-outline" style="position:absolute;top:10px;right:10px;" onclick="openRedeemModal()">🎁</button></div></div>
<div class="modal-overlay" id="redeemModal" style="display:none;"><div class="modal"><h3>🎁 兑换码</h3><input id="redeemInput" placeholder="输入兑换码" style="width:100%;padding:8px;background:var(--input-bg);border:1px solid var(--border);color:var(--text);border-radius:4px;margin:8px 0;"><button class="btn-gold btn-sm" onclick="redeemCode()">兑换</button><button class="btn-outline btn-sm" onclick="document.getElementById('redeemModal').style.display='none'" style="margin-left:5px;">退出</button><div id="redeemMsg" style="font-size:0.7em;margin-top:6px;"></div></div></div>
<div class="modal-overlay" id="winModal" style="display:none;"><div class="modal"><h2>🏆 天才交易员！</h2><p>资产破1亿</p><button class="btn-gold" onclick="continuePlaying()">继续</button></div></div>
<div class="modal-overlay" id="gameOverModal" style="display:none;"><div class="modal" style="border-color:#ef4444;"><h2 style="color:#ef4444;">已破产</h2><h3>GAME OVER</h3><p id="goReason"></p><button onclick="restartGame()">重新开始</button></div></div>
<div class="modal-overlay" id="jobModal" style="display:none;"><div class="modal"><h2>🔍 工作</h2><div id="jobListContainer"></div><button class="btn-outline" onclick="document.getElementById('jobModal').style.display='none'">取消</button></div></div>
<div class="modal-overlay" id="loanModal" style="display:none;"><div class="modal"><h2>🏦 贷款</h2><div id="loanListContainer"></div><button class="btn-outline" onclick="document.getElementById('loanModal').style.display='none'">取消</button></div></div>
<div class="modal-overlay" id="leverageModal" style="display:none;"><div class="modal"><h2>📈 杠杆融资</h2><div id="leverageContainer"></div><button class="btn-outline" onclick="document.getElementById('leverageModal').style.display='none'">取消</button></div></div>
<!-- 随机事件弹窗 -->
<div class="modal-overlay" id="eventModal" style="display:none;"><div class="modal" style="text-align:left;"><h2 id="eventTitle" style="text-align:center;"></h2><p id="eventDesc"></p><div id="eventOptions" style="display:flex; flex-direction:column; gap:6px; margin-top:10px;"></div></div></div>
<!-- 人脉互动弹窗 -->
<div class="modal-overlay" id="networkModal" style="display:none;"><div class="modal"><h3 id="networkCharName"></h3><p id="networkCharRole"></p><div id="networkActions" style="display:flex; flex-direction:column; gap:6px;"></div><button class="btn-outline btn-sm" onclick="document.getElementById('networkModal').style.display='none'" style="margin-top:10px;">关闭</button></div></div>

<script>
    const TARGET = 100_000_000;
    const INITIAL_CASH = 100_000;
    const MAX_STAMINA = 100;
    let gs = {
        day:0,cash:INITIAL_CASH,mood:60,stamina:MAX_STAMINA,credit:100,skill:60,
        holdings:{},assets:{},selectedAssetId:null,eventLog:[],
        gameOver:false,winAchieved:false,
        currentJob:null,daysWorkedInCycle:0,lastPayDay:0,
        loan:null,leverage:null,lastDonationDay:-1,lastLotteryDay:-1,
        ownedItems:[],unlockedAchievements:new Set(),credit100Days:0,
        overtimeUsed:false,leaveEarlyUsed:false,
        properties:{},lastMilestone:0,consecutiveProfitDays:0,lastTotalAsset:INITIAL_CASH,
        autoInvest:{enabled:false,fundId:'fund_steady',amount:1000},
        lotteryNoCooldown:false,redeemedCodes:new Set(),
        recommendedStock:null,
        // 人脉系统
        network:{colleagues:[], leader:null, boss:null},
        lastEventDay: -Infinity, // 上次随机事件天数
        bossBuff: false // 老板永久折扣
    };
    const JOB_DEFS = [
        {id:'rider',name:'外卖骑手',icon:'🛵',salary:3000,reqCash:0,reqAsset:0,reqCredit:50,reqSkill:0},
        {id:'clerk',name:'便利店店员',icon:'🏪',salary:4000,reqCash:2000,reqAsset:50000,reqCredit:70,reqSkill:0},
        {id:'office',name:'公司文员',icon:'💻',salary:6000,reqCash:50000,reqAsset:100000,reqCredit:80,reqSkill:70},
        {id:'coder',name:'程序员',icon:'⌨️',salary:50000,reqCash:500000,reqAsset:3000000,reqCredit:80,reqSkill:90},
        {id:'fundmgr',name:'基金经理',icon:'📈',salary:500000,reqCash:3000000,reqAsset:10000000,reqCredit:95,reqSkill:100},
    ];
    const LOAN_PRODUCTS = [
        {id:'small',name:'小额贷',amount:5000,rate:0.0005,minCredit:60},
        {id:'medium',name:'中额贷',amount:20000,rate:0.0008,minCredit:70},
        {id:'large',name:'大额贷',amount:50000,rate:0.001,minCredit:80},
    ];
    const assetDefs = [
        {id:'xingchen',name:'星辰科技',cat:'stock',initPrice:85,vol:0.04,icon:'⭐',risk:'high'},
        {id:'yundun',name:'云盾网络',cat:'stock',initPrice:156,vol:0.035,icon:'🛡️',risk:'mid'},
        {id:'lvyuan',name:'绿源能源',cat:'stock',initPrice:42,vol:0.03,icon:'🌿',risk:'mid'},
        {id:'tiangong',name:'天工智能',cat:'stock',initPrice:268,vol:0.045,icon:'🤖',risk:'high'},
        {id:'bihai',name:'碧海生物',cat:'stock',initPrice:73,vol:0.028,icon:'🧬',risk:'low'},
        {id:'longteng',name:'龙腾芯片',cat:'stock',initPrice:195,vol:0.042,icon:'💾',risk:'high'},
        {id:'yuanhang',name:'远航重工',cat:'stock',initPrice:28,vol:0.02,icon:'🚢',risk:'low'},
        {id:'jinsui',name:'金穗农业',cat:'stock',initPrice:15,vol:0.018,icon:'🌾',risk:'low'},
        {id:'feiyu',name:'飞宇航空',cat:'stock',initPrice:62,vol:0.032,icon:'✈️',risk:'mid'},
        {id:'jiguang',name:'极光传媒',cat:'stock',initPrice:38,vol:0.026,icon:'📺',risk:'mid'},
        {id:'fund_steady',name:'稳健增长基金',cat:'fund',initPrice:1.8,vol:0.008,icon:'🛡️',risk:'low'},
        {id:'fund_tech',name:'科技创新基金',cat:'fund',initPrice:2.3,vol:0.015,icon:'🚀',risk:'mid'},
        {id:'fund_dividend',name:'红利优选基金',cat:'fund',initPrice:1.2,vol:0.006,icon:'💎',risk:'low'},
        {id:'fund_global',name:'环球配置基金',cat:'fund',initPrice:3.5,vol:0.01,icon:'🌍',risk:'low'},
        {id:'gold',name:'黄金',cat:'metal',initPrice:480,vol:0.01,icon:'🥇',risk:'low'},
        {id:'silver',name:'白银',cat:'metal',initPrice:28,vol:0.02,icon:'🥈',risk:'mid'},
        {id:'copper',name:'铜',cat:'metal',initPrice:68,vol:0.018,icon:'🟤',risk:'mid'},
        {id:'rareearth',name:'稀土',cat:'metal',initPrice:320,vol:0.035,icon:'🔮',risk:'high'},
        {id:'lithium',name:'锂矿',cat:'metal',initPrice:185,vol:0.04,icon:'⚡',risk:'high'},
    ];
    const PROPERTY_DEFS = [
        {id:'apt1',name:'小公寓',price:500000,rent:2000,icon:'🏢'},
        {id:'house1',name:'普通住宅',price:2000000,rent:8000,icon:'🏡'},
        {id:'villa',name:'豪华别墅',price:10000000,rent:40000,icon:'🏰'},
    ];
    const SHOP_ITEMS = [
        {type:'watch',name:'劳力士',price:100000,icon:'⌚'},{type:'watch',name:'百达翡丽',price:50000000,icon:'⌚'},
        {type:'watch',name:'天梭',price:10000,icon:'⌚'},{type:'watch',name:'朗格',price:500000,icon:'⌚'},
        {type:'watch',name:'江诗丹顿',price:2000000,icon:'⌚'},{type:'car',name:'奔驰',price:500000,icon:'🚗'},
        {type:'car',name:'宝马',price:1000000,icon:'🚗'},{type:'car',name:'兰博基尼',price:40000000,icon:'🏎️'},
